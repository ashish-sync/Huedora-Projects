# Backend API origin (no trailing slash).
# Local Vite: leave empty to use the /api proxy in vite.config.js (default → localhost:5000).
# Direct / production example:
# VITE_BACKEND_URL=http://localhost:5000
VITE_BACKEND_URL=

# Camp One talks to TYLO /api/v1/camp-ops using the same session as the rest of the app.
# No extra Camp One frontend env vars are required when using the Vite proxy.
